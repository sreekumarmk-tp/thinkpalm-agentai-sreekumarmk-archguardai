# Required: API keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Provider to use if no prefix (groq/ or openrouter/) is provided in model name
# Options: openrouter, groq
DEFAULT_LLM_PROVIDER=groq

# Optional but recommended: improves GitHub API rate limits
GITHUB_TOKEN=your_github_personal_access_token_here

# Global Free Models Lists (Used to populate UI selection and defaults)
# Verified against live APIs on 2026-04-18 (probed with actual chat completions call)
GROQ_FREE_MODELS=llama-3.3-70b-versatile,meta-llama/llama-4-scout-17b-16e-instruct,llama-3.1-8b-instant,qwen/qwen3-32b,openai/gpt-oss-120b,openai/gpt-oss-20b,openai/gpt-oss-safeguard-20b,meta-llama/llama-prompt-guard-2-86m,meta-llama/llama-prompt-guard-2-22m

# OpenRouter: only models verified to respond successfully (200 OK) as of 2026-04-18
OPENROUTER_FREE_MODELS=openai/gpt-oss-120b:free,google/gemma-3-27b-it:free,meta-llama/llama-3.3-70b-instruct:free,qwen/qwen3.6-plus:free


# Agent-specific free model preferences (Groq)
GROQ_ARCHITECT_DESIGN=llama-3.3-70b-versatile,meta-llama/llama-4-scout-17b-16e-instruct,qwen/qwen3-32b
GROQ_SECURITY_QUALITY=llama-3.1-8b-instant,llama-3.3-70b-versatile,meta-llama/llama-prompt-guard-2-86m,meta-llama/llama-prompt-guard-2-22m
GROQ_PERFORMANCE_TESTING=qwen/qwen3-32b,llama-3.3-70b-versatile,llama-3.1-8b-instant
GROQ_REPORT_SYNTHESIZER=llama-3.3-70b-versatile,openai/gpt-oss-120b,openai/gpt-oss-20b,openai/gpt-oss-safeguard-20b

# Agent-specific free model preferences (OpenRouter) — all models verified working 2026-04-18
OPENROUTER_ARCHITECT_DESIGN=openai/gpt-oss-120b:free
OPENROUTER_SECURITY_QUALITY=google/gemma-3-27b-it:free
OPENROUTER_PERFORMANCE_TESTING=qwen/qwen3.6-plus:free
OPENROUTER_REPORT_SYNTHESIZER=meta-llama/llama-3.3-70b-instruct:free
